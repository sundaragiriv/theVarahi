---
const LOGOS = Astro.props?.logos ?? [
  {src:'/logos/logo1.svg', alt:'Client A'}, {src:'/logos/logo2.svg', alt:'Client B'},
  {src:'/logos/logo3.svg', alt:'Client C'}, {src:'/logos/logo4.svg', alt:'Client D'}
];
---
<section class="py-8 border-y border-black/5 bg-white/60 backdrop-blur">
  <div class="container mx-auto max-w-[1200px] 2xl:max-w-[1280px] px-4">
    <div class="text-xs tracking-wide text-slate-500 mb-4">TRUSTED FOR SAP CX IMPLEMENTATION</div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6 items-center opacity-80">
      {LOGOS.map(l => <img src={l.src} alt={l.alt} loading="lazy" decoding="async" class="h-8 w-auto mx-auto" />)}
    </div>
  </div>
</section>
