---
const cases = Astro.props?.items ?? [
  {title:"Service V2 Modernization", summary:"Action Profiles → flows; SLA breaches −32%", href:"/case-studies/action-profiles-modern-flows"},
  {title:"Sales V2 + CPQ", summary:"Quote time −60% with governed pricing", href:"/case-studies/sales-cpq-governed"},
  {title:"FSM Field Ops", summary:"Dispatch accuracy +15%", href:"/case-studies/fsm-field-ops"},
];
---
<section id="work" class="py-12">
  <div class="container mx-auto max-w-[1200px] 2xl:max-w-[1280px] px-4">
    <div class="flex items-end justify-between">
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">Selected case studies</h2>
      <a href="/case-studies" class="text-sm text-[#0070F2] underline">See all</a>
    </div>
    <div class="mt-6 overflow-x-auto">
      <div class="flex gap-4 snap-x snap-mandatory pb-2">
        {cases.map(c => (
          <a href={c.href} class="min-w-[280px] md:min-w-[360px] lg:min-w-[420px] snap-start rounded-2xl bg-white border border-black/10 p-6 shadow-soft hover:shadow-lift transition">
            <h3 class="text-lg font-semibold">{c.title}</h3>
            <p class="mt-1 text-sm text-slate-600">{c.summary}</p>
            <span class="mt-3 inline-flex items-center gap-1 text-sm text-[#0070F2]">Read →</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
