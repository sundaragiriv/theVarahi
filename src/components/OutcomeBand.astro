---
const items = Astro.props?.items ?? [
  {k:"SLA breach rate", v:"−25–40%"},
  {k:"Quote cycle time", v:"−30–50%"},
  {k:"Time to resolution", v:"−20–30%"},
  {k:"Adoption (DAU/WAU)", v:"↑ steady"}
];
---
<section id="outcomes" class="py-12">
  <div class="container mx-auto max-w-[1200px] 2xl:max-w-[1280px] px-4">
    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">Outcomes you can expect</h2>
    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {items.map(it => (
        <div class="rounded-2xl bg-white border border-black/10 p-6 shadow-soft hover:shadow-lift transition">
          <div class="text-xs text-slate-500">{it.k}</div>
          <div class="text-2xl font-semibold text-slate-900">{it.v}</div>
        </div>
      ))}
    </div>
  </div>
</section>
