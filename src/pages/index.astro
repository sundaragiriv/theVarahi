---
import StickySubnav from "../components/StickySubnav.astro";
import GlowOrbs from "../components/GlowOrbs.astro";
import GridSparkle from "../react/GridSparkle.tsx";
import TrustBar from "../components/TrustBar.astro";
import OutcomeBand from "../components/OutcomeBand.astro";
import CaseScroller from "../components/CaseScroller.astro";
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Varahi UX Enhancements Demo</title>
  </head>
  <body class="bg-white text-slate-900">
    <section id="hero" class="relative py-20 flex flex-col items-center justify-center min-h-[60vh]">
      <GridSparkle client:visible speed={0.7} density={0.0016} />
      <GlowOrbs tint="#0070F2" opacity={0.12} />
      <h1 class="text-4xl font-bold mb-4">Welcome to Varahi</h1>
      <p class="text-lg mb-8">Experience premium UX enhancements: sticky subnav, glows, and grid sparkles.</p>
      <a href="#contact" class="btn-accent px-6 py-3 rounded-lg font-semibold shadow-lg">Contact Us</a>
    </section>
    <TrustBar />
    <StickySubnav sections={[
      { id: 'services', label: 'Services' },
      { id: 'outcomes', label: 'Outcomes' },
      { id: 'work', label: 'Case Studies' },
      { id: 'insights', label: 'Insights' },
      { id: 'contact', label: 'Contact' },
    ]} />
    <section id="services" class="relative py-16">
      <h2 class="text-2xl font-bold mb-4">Services</h2>
      <p>Our offerings are tailored for growth and innovation.</p>
    </section>
    <OutcomeBand />
    <section id="work" class="relative py-16">
      <h2 class="text-2xl font-bold mb-4">Case Studies</h2>
      <p>Explore our portfolio of successful projects.</p>
    </section>
    <section id="insights" class="relative py-16">
      <h2 class="text-2xl font-bold mb-4">Insights</h2>
      <p>Thought leadership and industry trends.</p>
    </section>
    <section id="contact" class="relative py-16">
      <GlowOrbs tint="#0070F2" opacity={0.14} />
      <h2 class="text-2xl font-bold mb-4">Contact</h2>
      <p>Get in touch to start your project.</p>
    </section>
  </body>
</html>
