# --- Contact form -----------------------------------------------------------
# Where the form POSTs. For Cloudflare Pages, use the built-in Function:
VITE_CONTACT_ENDPOINT=/api/contact
# (Or point at Formspree/Basin/etc. instead, e.g. https://formspree.io/f/xxxx.)
# Leave BLANK to fall back to a pre-filled mailto: so the CTA always works.

# Address shown on the site and used by the mailto fallback.
VITE_CONTACT_EMAIL=hello@thevarahi.com

# --- Cloudflare Pages Function (functions/api/contact.js) --------------------
# Set these in Cloudflare Pages → Settings → Environment variables (NOT here):
#   RESEND_API_KEY   your Resend (resend.com) API key
#   CONTACT_TO       where submissions land, e.g. hello@thevarahi.com
#   CONTACT_FROM     verified sender, e.g. "Varahi <hello@thevarahi.com>"
#                    (use "Varahi <onboarding@resend.dev>" before domain verify)
