# EmailJS Configuration
# Get these from your EmailJS dashboard: https://www.emailjs.com/

# Service ID from EmailJS dashboard
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# Template IDs for different email types
VITE_EMAILJS_TEMPLATE_CONTACT=template_contact_form
VITE_EMAILJS_TEMPLATE_NEWSLETTER=template_newsletter_sub

# Public Key from EmailJS dashboard (safe to expose in frontend)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Optional: Analytics and tracking
VITE_ENABLE_FORM_ANALYTICS=true